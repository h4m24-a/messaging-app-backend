sorting ids

const [user1Id, user2Id] =
  userA < userB ? [userA, userB] : [userB, userA]; 
  so if the condition is true, assign userA to user1_id, and b to 2, if not assign userb to user1_id and a to 2

  user1_id should be < than user2Id


user1Id = min(userA, userB)
