generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Users {
  id                                        Int            @id @default(autoincrement())
  username                                  String         @unique @db.VarChar(50)
  password                                  String
  profile_image                             String?
  bio                                       String?
  created_at                                DateTime     @default(now()) @db.Timestamp(6)
  refreshtoken                              String?
  conversationsAsUser1                      Conversation[] @relation("User1Conversation") // “all conversations where this user is user1”
  conversationsAsUser2                      Conversation[] @relation("User2Conversation") // “all conversations where this user is user2”
  messages                                  Messages[]
}




model Conversation {
  id                                 Int        @id @default(autoincrement())
  user1Id                           Int
  user2Id                           Int
  user1 Users @relation("User1Conversation", fields: [user1Id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user1")  // id of user1 lineked to users model
  user2 Users @relation("User2Conversation", fields: [user2Id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user2") // id of users2 linked to users model
  created_at                         DateTime  @default(now()) @db.Timestamp(6)
  messages                           Messages[]

  @@unique([user1Id, user2Id], map: "unique_user_pair")
}



model Messages {
  id                Int               @id @default(autoincrement())
  text              String?
  conversationId   Int 
  senderId         Int
  seen              Boolean          @default(false)
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @updatedAt
  conversation      Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_conversation")  // conversation id as FK
  sender            Users           @relation(fields: [senderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sender")  // user id as FK
}




